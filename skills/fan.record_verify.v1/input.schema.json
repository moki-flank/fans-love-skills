{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Record Verify Input",
  "type": "object",
  "required": [
    "user_id"
  ],
  "properties": {
    "user_id": {
      "type": "string"
    },
    "card_id": {
      "type": "string"
    },
    "record_url": {
      "type": "string",
      "format": "uri"
    },
    "claimed_amount": {
      "type": "number",
      "minimum": 0
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
