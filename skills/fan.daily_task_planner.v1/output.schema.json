{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily Task Planner Output",
  "type": "object",
  "required": [
    "summary",
    "recommended_tasks"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "recommended_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "priority",
          "reason"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "pet_suggestion": {
      "type": "string"
    },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
