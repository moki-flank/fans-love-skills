{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Daily Task Planner Input",
  "type": "object",
  "required": [
    "user_id"
  ],
  "properties": {
    "user_id": {
      "type": "string"
    },
    "card_id": {
      "type": "string"
    },
    "points": {
      "type": "integer",
      "minimum": 0
    },
    "pet_intimacy": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "current_star": {
      "type": "object",
      "additionalProperties": true
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "current_progress": {
            "type": "integer"
          },
          "total_progress": {
            "type": "integer"
          },
          "reward_points": {
            "type": "integer"
          },
          "is_completed": {
            "type": "boolean"
          },
          "is_claimable": {
            "type": "boolean"
          },
          "type": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
