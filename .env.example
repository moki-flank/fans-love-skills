GITHUB_PAGES_BASE_URL=https://moki-flank.github.io/fans-love-skills

# n8n API, never commit the real key.
N8N_BASE_URL=https://your-n8n.example
N8N_API_KEY=replace_with_local_key
N8N_WORKFLOW_DIR=n8n/workflows

# Required only when you are ready to intentionally delete every n8n workflow.
N8N_CONFIRM_WIPE=

# Runtime or worker database connection. Keep the real value in .env.local.
DATABASE_URL=postgres://user:password@host:5432/fans_love

# Large-model agent loop. Real keys must stay in .env.local.
AGENT_RUNTIME_MODE=auto
AGENT_MAX_STEPS=20
OPENAI_API_KEY=replace_with_local_openai_key
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
